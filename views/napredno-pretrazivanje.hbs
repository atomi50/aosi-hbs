<div class="container-fluid content-wrapper p-0 flex-grow-1">
        <!-- Banner -->
        <div class="container-fluid banner__visual">
            {{> banner__inner}}
           {{> shape__divider}}
        </div>
        <div onclick="toggleSidebar()" class="filter__button" aria-hidden="true"><i
                class="bi bi-person-fill filterButton" aria-label="Prikaži opcije mog repozitorija" tabindex="-1"></i>
        </div>
        <div class="container-xxl filterContent__container">
            <section class="card card__filters" aria-label="filtriranje">
                <div class="card-body card__filters-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="card-title">Filtriraj prema</h2><span onclick="toggleSidebar()"
                            aria-label="Sakrij opcije mog repozitorija"><i class="bi bi-box-arrow-left filterButton"
                                tabindex="0"></i></span>
                    </div>
                    <p class="card-text">
                    <h4>USTANOVAMA I ODJELIMA</h4>
                    <ul>
                        <li><a href="">Postavke repozitorija<span
                                    class="ms-1 badge text-bg-danger rounded-pill">10</span></a>
                        </li>
                        <li><a href="">Izgled repozitorija<span
                                    class=" ms-1 badge text-bg-danger rounded-pill">10</span></a>
                        </li>
                        <li><a href="">Korisnici<span class="ms-1 badge text-bg-danger rounded-pill">10</span></a>
                        </li>
                        <li><a href="">Pohranitelji objekata</a></li>
                        <li><a href="">Neaktivni objekti<span
                                    class="ms-1 badge text-bg-danger rounded-pill">10</span></a>
                        </li>
                        <li><a href="">Zahtjevi za pristup objektima</a></li>
                        <li><a href="">Često postavljana pitanja</a><i class="ms-2 bi bi-box-arrow-up-right"></i>
                        </li>
                        <li><a href="">Moji objekti</a></li>
                        <li><a href="">Moje liste</a></li>
                    </ul>
                    </p>
                </div>
            </section>
            <section id="napredno-pretrazivanje__content" class="card w-100"
                aria-label="napredno pretraživanje objekata">
                <div class=" card-body">
                    <div class="p-3 rounded-3 bg-body-tertiary">
                        <h2 class="mb-4">Postavite uvjet</h2>
                        <div id="rowsContainer">
                            <div class="row mt-1" id="templateRow">
                                <div class="col-lg-1">
                                    <select class="form-select" aria-label="odaberite uvjet za selektiranje" hidden>
                                        <option selected>i</option>
                                        <option value="1">ili</option>
                                    </select>
                                </div>
                                <div class="col-lg-2 mt-1">
                                    <select class="form-select" aria-label="odaberite polje">
                                        <option selected>Odaberite polje</option>
                                        <option value="1">Naslov</option>
                                        <option value="1">Autor</option>
                                        <option value="1">Ključne riječi</option>
                                        <option value="1">Naslov publikacije</option>
                                        <option value="1">Sažetak</option>
                                    </select>
                                </div>
                                <div class="col-lg-3 mt-1">
                                    <select class="form-select" aria-label="odaberite uvjet">
                                        <option selected>Odaberite uvjet</option>
                                        <option value="1">Sadrži sve ove riječi</option>
                                        <option value="1">Sadrži točno ovu riječ ili izraz</option>
                                        <option value="1">Sadrži bilo koju od ovih riječi</option>
                                        <option value="1">Ne sadrži nijednu od ovih riječi</option>
                                    </select>
                                </div>
                                <div class="col-lg-6 mt-1">
                                    <input type="text" class="form-control" placeholder="upišite riječi"
                                        aria-label="Sizing example input">
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-2">
                            <button id="removeRowBtn" class="btn btn-outline-info me-2" style="display: none;">- ukloni
                                zadnji
                                uvjet</button>
                            <button class="btn btn-primary-soft" id="addAnotherRowBtn">+ dodaj još jedan uvjet</button>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end m-3">
                        <button class="btn btn-primary d-flex justify-content-end">Pretraži</button>
                    </div>
                    <hr aria-hidden="true">
                    <h3 class="mt-5 mb-4">Prilagodite pretraživanje prema kriterijima</h3>
                    <h4 class="mt-2">Vrsta objekta</h4>
                    <div class="row">
                        <div class="col-lg-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="zavrsni" />
                                <label class="form-check-label" for="zavrsni">Završni, diplomski i
                                    specijalistički rad</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="doktorski" />
                                <label class="form-check-label" for="doktorski">Doktorski i znanstveni
                                    magistarski radovi</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="prilog-ocjenskom" />
                                <label class="form-check-label" for="prilog-ocjenskom">Prilog ocjenskom
                                    radu</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="umjetnicki" />
                                <label class="form-check-label" for="umjetnicki">Umjetnički završni i
                                    diplomski
                                    radovi</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="prilog-casopisu" />
                                <label class="form-check-label" for="prilog-casopisu">Prilog u časopisu</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="prilog-skup" />
                                <label class="form-check-label" for="prilog-skup">Prilog sa skupa (u
                                    zborniku)</label>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="knjiga" />
                                <label class="form-check-label" for="knjiga">Knjiga</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="prilog-u-knjizi" />
                                <label class="form-check-label" for="prilog-u-knjizi">Prilog u knjizi</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="izlaganje-na-skupu" />
                                <label class="form-check-label" for="izlaganje-na-skupu">Izlaganje sa skupa</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="druge-vrste" />
                                <label class="form-check-label" for="druge-vrste">Druge vrste
                                    dokumenata</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="plan-upravljanja" />
                                <label class="form-check-label" for="plan-upravljanja">Plan upravljanja
                                    istraživačkim
                                    podacima</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="slikovna-grada" />
                                <label class="form-check-label" for="slikovna-grada">Slikovna građa</label>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="audio-grada" />
                                <label class="form-check-label" for="audio-grada">Audio građa</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="audiovizualna-grada" />
                                <label class="form-check-label" for="audiovizualna-grada">Audiovizualna građa</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="obrazovni-sadrzaj" />
                                <label class="form-check-label" for="obrazovni-sadrzaj">Obrazovni sadržaj</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="skup-podataka" />
                                <label class="form-check-label" for="skup-podataka">Skup podataka /
                                    istraživački</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="virtualna-zbirka" />
                                <label class="form-check-label" for="virtualna-zbirka">Virtualna zbirka</label>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div>
                            <h4 class="mt-5">Godina izdavanja</h4>
                            <div class="d-flex">
                                <div class="col-lg-6 pe-2">
                                    <select class="form-select" aria-label="odaberite početno godište">
                                        <option selected>1870</option>
                                        <option value="1">1871</option>
                                        <option value="2">1872</option>
                                        <option value="3">1873</option>
                                        <option value="4">1874</option>
                                        <option value="5">1875</option>
                                    </select>
                                </div>
                                <div class="col-lg-6">
                                    <select class="form-select" aria-label="odaberite završno godište">
                                        <option selected>2025</option>
                                        <option value="1">2024</option>
                                        <option value="2">2023</option>
                                        <option value="3">2022</option>
                                        <option value="4">2021</option>
                                        <option value="5">2020</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div>
                            <h4 class="mt-5">Prava pristupa</h4>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="otvoren-pristup" />
                                <label class="form-check-label" for="otvoren-pristup">Otvoren pristup</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="institucijski-pristup" />
                                <label class="form-check-label" for="institucijski-pristup">Institucijski
                                    pristup</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="nedostupan-rad" />
                                <label class="form-check-label" for="nedostupan-rad">Nedostupan rad</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="autoriziran-pristup" />
                                <label class="form-check-label" for="autoriziran-pristup">Autoriziran
                                    pristup</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="" id="privremeno-nedostupan" />
                                <label class="form-check-label" for="privremeno-nedostupan">Privremeno
                                    nedostupan
                                    rad</label>
                            </div>
                        </div>
                    </div>
                    <h4 class="mt-5">Područja i polja znanosti</h4>
                    <div class="row">
                        <div class="col-lg-12">
                            <select class="form-select" size="10" multiple
                                aria-label="odaberite područje i polja znanosti">
                                <option value="1">Prirodne znanosti</option>
                                <option value="10" class="ms-3">Matematika</option>
                                <option value="11" class="ms-3">Fizika</option>
                                <option value="12" class="ms-3">Geologija</option>
                                <option value="13" class="ms-3">Kemija</option>
                                <option value="14" class="ms-3">Biologija</option>
                                <option value="15" class="ms-3">Geofizika</option>
                                <option value="16" class="ms-3">Interdisciplinarne prirodne znanosti</option>
                                <option value="2">Tehničke znanosti</option>
                                <option value="10" class="ms-3">Arhitektura i urbanizam</option>
                                <option value="11" class="ms-3">Brodogradnja</option>
                                <option value="12" class="ms-3">Elektrotehnika</option>
                                <option value="13" class="ms-3">Geodezija</option>
                                <option value="14" class="ms-3">Građevinarstvo</option>
                                <option value="15" class="ms-3">Grafička tehnologija</option>
                                <option value="16" class="ms-3">Kemijsko inženjerstvo</option>
                                <option value="16" class="ms-3">Metalurgija</option>
                                <option value="16" class="ms-3">Računarstvo</option>
                                <option value="16" class="ms-3">Rudarstvo, nafta i geološko inženjerstvo</option>
                                <option value="16" class="ms-3">Strojarstvo</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-end m-3">
                    <button class="btn btn-primary d-flex justify-content-end">Pretraži</button>
                </div>
        </div>
    </div>
