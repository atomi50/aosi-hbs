<div class="d-flex flex-column flex-md-row justify-content-between my-2">
  <div>
    <p class="text-black fw-bold d-inline">
      {{text}}
    </p>
    <span>({{code}})</span>
    <a class="text-danger text-decoration-none" data-bs-toggle="collapse" href="#{{identificator}}" role="button"
      aria-expanded="false" aria-controls="{{identificator}}">
      info
    </a>
    <div class="collapse" id="{{identificator}}">
      <div class="card card-body">
        {{description}}
      </div>
    </div>
  </div>
  <div>
    {{#if select}}
      <select class="form-select">
        {{#each options}}
          <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    {{else}}
      {{#if input}}
        <div>
          <label for="input-id" class="form-label visually-hidden">inputLabel</label>
          <input type="{{input.type}}" class="form-control" id="input-id" aria-describedby="{{input.aria}}"
            placeholder="{{input.placeholder}}" />
        </div>
      {{else}}
        {{#if file}}
          <div>
            <form action="/action_page.php" method="post" enctype="multipart/form-data">
              <label for="file-upload" class="form-label mt-1 me-4"><svg xmlns="http://www.w3.org/2000/svg" width="20"
                  height="20" fill="currentColor" class="bi bi-upload" viewBox="0 0 16 16">
                  <path
                    d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5" />
                  <path
                    d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z" />
                </svg>
              </label>
              <input type="file" id="file-upload" name="file-upload" class="form-control d-none">
            </form>
          </div>
        {{else}}
          <p>{{value}}</p>
        {{/if}}
      {{/if}}
    {{/if}}
  </div>

</div>