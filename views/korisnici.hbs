<div class="container-fluid content-wrapper p-0 flex-grow-1">
    <div class="container-fluid banner__visual">
        {{> banner__inner}}
        {{> shape__divider}}
    </div>
    <!-- End of banner beginning of content cards -->
    <div onclick="toggleSidebar()" class="filter__button" aria-hidden="true"><i class="bi bi-person-fill filterButton"
            aria-label="Prikaži izbornik" tabindex="-1"></i>
    </div>
    <section id="main" class="container-xxl filterContent__container" aria-label="sadržaj">
        <section class="card card__filters" aria-label="filtriranje">
            <div class="card-body card__filters-body">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="card-title"></h2><span onclick="toggleSidebar()"
                        aria-label="Sakrij opcije mog repozitorija"><i class="bi bi-box-arrow-left filterButton"
                            tabindex="0"></i></span>
                </div>
                <div class="card-text">
                    <ul>
                        <li><a href="">Ažuriranje podataka</a></li>
                        <li><a href="">Promjena zaporke</a></li>
                    </ul>
                </div>
            </div>
        </section>
        <section class="card">
            <div class="card-body">
                <h2 class="card-title m-0 pb-0">Ažuriranje podataka</h2>
                <div class="mt-5">
                    {{> atributi text="Korisnička oznaka" code="(hrEduPersonUniqueID)" identificator="korisnickaOznaka" description="Vrijednost atributa je jedinstvena korisnička oznaka osobe u sustavu AAI@Edu.hr.
                                    Koristi se pri interinstitucionalnoj autentikaciji.
                                    Sintaksa: <lokalni_id>@<identifikator_imenika>
                                            lokalni_id jednoznačno identificira osobu na nivou matične ustanove;
                                            lokalni_id mora odgovarati vrijednosti atributa uid odnosno identifikatoru
                                            korisnika u ustanovi.
                                            identifikator_imenika jednoznačno identificira ustanovu; izvodi se iz DNS
                                            sustava (npr. za ustanovu koja u DNS-u ima domenu)" value="jpslavc@aai-test.hr"}}
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-black fw-bold d-inline">
                                Identifikator korisnika u ustanovi</p> <span> (uid)</span><a
                                class="text-danger text-decoration-none" data-bs-toggle="collapse" href="#identifikator"
                                role="button" aria-expanded="false" aria-controls="identifikator"> info</a>
                            <div class="collapse" id="identifikator">
                                <div class="card card-body">
                                    Identifikator korisnika (u pravilu login-name; userid) kojom se identificira osoba
                                    na matičnoj ustanovi (lokalno); može se rabiti za (lokalnu) autentikaciju; mora
                                    imati istu vrijednost kao lokalni_id u atributu hrEduPersonUniqueID (korisnička
                                    oznaka).
                                </div>
                            </div>
                        </div>
                        <div>
                            <p>jpslavc</p>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-black fw-bold d-inline">
                                Ime i prezime</p> <span>(cn)</span><a class="text-danger text-decoration-none"
                                data-bs-toggle="collapse" href="#imePrezime" role="button" aria-expanded="false"
                                aria-controls="imePrezime">
                                info</a>
                            <div class="collapse" id="imePrezime">
                                <div class="card card-body">
                                    Puno ime i prezime osobe
                                </div>
                            </div>
                        </div>
                        <div>
                            <p>Jasmina Plavac</p>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-black fw-bold d-inline">
                                Prezime</p> <span>(sn)</span><a class="text-danger text-decoration-none"
                                data-bs-toggle="collapse" href="#prezime" role="button" aria-expanded="false"
                                aria-controls="prezime">
                                info</a>
                            <div class="collapse" id="prezime">
                                <div class="card card-body">
                                    Prezime osobe
                                </div>
                            </div>
                        </div>
                        <div>
                            <p>Plavac</p>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-black fw-bold d-inline">
                                Ime</p> <span>(sn)</span><a class="text-danger text-decoration-none"
                                data-bs-toggle="collapse" href="#ime" role="button" aria-expanded="false"
                                aria-controls="ime">
                                info</a>
                            <div class="collapse" id="ime">
                                <div class="card card-body">
                                    Ime osobe
                                </div>
                            </div>
                        </div>
                        <div>
                            <p>Jasmina</p>
                        </div>
                    </div>
                    {{> atributi text="Elektronička pošta" code="mail" identificator="email" description="Elektronička adresa osobe; nužno je da jedna od vrijednosti ovoga atributa bude i službena elektronička adresa osobe (ona koju matična ustanova koristi za korespodenciju s osobom)." value="jplavac@srce.hr"}}
                </div>
            </div>
        </section>
    </section>
</div>